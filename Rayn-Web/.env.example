# ──────────────────────────────────────────────────────────────────────
# RAYN SAAS ENVIRONMENT VARIABLE CONFIGURATION TEMPLATE
# Copy this file to '.env' and populate with your own API keys/secrets.
# ──────────────────────────────────────────────────────────────────────

# ── DATABASE & PERSISTENCE ────────────────────────────────────────────
# The connection URL for Amazon Aurora PostgreSQL / Serverless RDS.
# Example: postgresql://username:password@rds-endpoint.amazonaws.com:5432/rayndb?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rayndb?schema=public"

# ── NEXTAUTH AUTHENTICATION ───────────────────────────────────────────
# Secret used to encrypt session tokens (generate using 'openssl rand -base64 32')
NEXTAUTH_SECRET="your_nextauth_jwt_secret_phrase"
# The public canonical URL of the application
NEXTAUTH_URL="http://localhost:3000"

# ── COGNITO USER POOLS (AUTH STACK) ───────────────────────────────────
# The App Client ID configured in your AWS Cognito User Pool.
COGNITO_CLIENT_ID="your_cognito_app_client_id"
# The App Client Secret configured in your AWS Cognito App Client.
COGNITO_CLIENT_SECRET="your_cognito_app_client_secret"
# The OpenID Connect issuer URL for the User Pool.
# Format: https://cognito-idp.[region].amazonaws.com/[user-pool-id]
COGNITO_ISSUER="https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx"

# ── AWS CLOUD SDK CREDENTIALS (S3, BEDROCK, DYNAMODB) ─────────────────
# The AWS region where services are provisioned.
AWS_REGION="us-east-1"
# AWS IAM User credentials with policies enabling Bedrock Runtime, S3 bucket access, and DynamoDB.
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# Optional Session token if utilizing temporary IAM assume-role credentials
AWS_SESSION_TOKEN=""

# ── S3 & DOCUMENTS STACK ──────────────────────────────────────────────
# Name of the Amazon S3 Bucket to store and ingest legal documents.
AWS_S3_BUCKET="rayn-legal-documents-storage"

# ── STRIPE BILLING & SUBSCRIPTIONS ────────────────────────────────────
# Stripe Secret API Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"
# Stripe Webhook Signing Secret (starts with whsec_ for verifying webhook events signature)
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── STRIPE PLAN PRICES (SUBSCRIPTION TIERS) ───────────────────────────
# Stripe price IDs mapped to SaaS subscription tiers (create recurring prices in Stripe Dashboard)
STRIPE_PRICE_PROFESSIONAL="price_1xxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ENTERPRISE="price_1xxxxxxxxxxxxxxxxx"
STRIPE_PRICE_UNLIMITED="price_1xxxxxxxxxxxxxxxxx"

# ── GEMINI & GENERAL FALLBACKS ────────────────────────────────────────
# Required fallback API key for alternative text summarization tasks.
GEMINI_API_KEY="your_gemini_api_key_here"
APP_URL="http://localhost:3000"
